          },
          "scanner": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "position": {
            "type": "integer"
          },
          "error": {
            "type": "boolean"
          },
          "numsubpods": {
            "type": "integer"
          },
          "primary": {
            "type": "boolean"
          },
          "subpods": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Subpod"
            }
          },
          "states": {
            "type": "object",
            "additionalProperties": true
          },
          "infos": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      },
      "Subpod": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "plaintext": {
            "type": "string"
          },
          "img": {
            "$ref": "#/components/schemas/WolframImage"
          },
          "mathml": {
            "type": "string"
          },
          "minput": {
            "type": "string"
          },
          "moutput": {
            "type": "string"
          },
          "cell": {
            "type": "string"
          },
          "states": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      },
      "WolframImage": {
        "type": "object",
