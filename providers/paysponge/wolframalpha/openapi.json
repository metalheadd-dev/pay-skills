                                }
                              }
                            ]
                          }
                        ]
                      }
                    }
                  }
                }
              },
              "application/xml": {
                "schema": {
                  "type": "string"
                },
                "example": "<queryresult success=\"true\" error=\"false\" numpods=\"4\" datatypes=\"Tide\" timedout=\"\" timedoutpods=\"\" timing=\"2.041\" parsetiming=\"0.159\" parsetimedout=\"false\" recalculate=\"\" id=\"MSPa2841c605802big7c5h700001bi6h0g908bch9ei\" host=\"http://www1.wolframalpha.com\" server=\"13\" version=\"2.6\"><pod title=\"Input interpretation\" scanner=\"Identity\" id=\"Input\" position=\"100\" error=\"false\" numsubpods=\"1\">...</pod><pod title=\"Result\" scanner=\"Tide\" id=\"Result\" position=\"200\" error=\"false\" numsubpods=\"1\" primary=\"true\">...</pod></queryresult>"
              },
              "text/xml": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "The request did not include a valid input parameter.",
            "content": {
              "text/plain": {
                "schema": {
