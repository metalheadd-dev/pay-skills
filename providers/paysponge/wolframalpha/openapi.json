  "info": {
    "title": "Wolfram Alpha",
    "version": "1.0.0",
    "description": "Wolfram|Alpha computational knowledge API through PaySponge x402. This bundled spec preserves the live PaySponge payment metadata and enriches the three exposed routes with the documented Wolfram request parameters and response types for short answers, simple images, and full results.",
    "x-agentcash-auth": {
      "mode": "paid"
    }
  },
