        ],
        "additionalProperties": true
      },
      "QueryResult": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "error": {
            "type": "boolean"
          },
          "numpods": {
            "type": "integer"
          },
          "datatypes": {
            "type": "string"
          },
          "timedout": {
            "type": "string"
          },
          "timedoutpods": {
            "type": "string"
          },
          "timing": {
            "type": "number"
          },
          "parsetiming": {
            "type": "number"
          },
          "parsetimedout": {
            "type": "boolean"
          },
          "recalculate": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "host": {
            "type": "string"
          },
          "server": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "pods": {
            "type": "array",
