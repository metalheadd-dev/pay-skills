            "x402"
          ],
          "pricingMode": "fixed",
          "price": "$0.01"
        },
        "x402Version": 2,
        "resource": {
          "url": "https://wolframalpha.x402.paysponge.com/v1/result",
          "description": "GET /v1/result",
          "mimeType": "application/json"
        },
        "accepts": [
          {
            "scheme": "exact",
            "network": "eip155:8453",
            "payTo": "0xD73912BA30832328a3db96BeE73ebfaB58b7429f",
            "asset": "usdc",
            "amount": "10000",
            "maxTimeoutSeconds": 300,
            "extra": {}
          },
          {
            "scheme": "exact",
            "network": "eip155:43114",
            "payTo": "0xD73912BA30832328a3db96BeE73ebfaB58b7429f",
            "asset": "usdc",
            "amount": "10000",
            "maxTimeoutSeconds": 300,
            "extra": {}
          },
          {
            "scheme": "exact",
            "network": "solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp",
            "payTo": "9hw9Py9uMGtXRNpABZjifcK1t3suwzjyri9L9QYKg6zZ",
            "asset": "usdc",
            "amount": "10000",
            "maxTimeoutSeconds": 300,
            "extra": {}
          }
        ],
        "extensions": {
          "bazaar": {
            "info": {
              "input": {
                "type": "http",
                "method": "GET",
                "query": {
                  "i": "How far is Los Angeles from New York?",
                  "units": "metric"
                }
              },
              "output": {
                "type": "text",
                "example": "3966 kilometers"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "A short textual answer returned directly from Wolfram|Alpha.",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                },
                "examples": {
                  "distance": {
                    "value": "2464 miles"
                  },
                  "metricDistance": {
                    "value": "3966 kilometers"
                  }
                }
              }
            }
          },
          "400": {
            "description": "The request did not include a valid input parameter.",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                },
                "example": "Error 1000: Input parameter not present in query"
              }
            }
          },
          "402": {
            "description": "Payment Required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/X402PaymentRequired"
                },
                "example": {
                  "x402Version": 2,
                  "error": "Payment required",
                  "resource": {
                    "url": "https://wolframalpha.x402.paysponge.com/v1/result",
                    "description": "GET /v1/result",
                    "mimeType": "application/json"
                  },
                  "accepts": [
                    {
                      "scheme": "exact",
                      "network": "eip155:8453",
                      "payTo": "0xD73912BA30832328a3db96BeE73ebfaB58b7429f",
                      "asset": "usdc",
                      "amount": "10000",
                      "maxTimeoutSeconds": 300,
                      "extra": {}
                    },
                    {
                      "scheme": "exact",
                      "network": "eip155:43114",
                      "payTo": "0xD73912BA30832328a3db96BeE73ebfaB58b7429f",
                      "asset": "usdc",
                      "amount": "10000",
                      "maxTimeoutSeconds": 300,
                      "extra": {}
                    },
                    {
                      "scheme": "exact",
                      "network": "solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp",
                      "payTo": "9hw9Py9uMGtXRNpABZjifcK1t3suwzjyri9L9QYKg6zZ",
                      "asset": "usdc",
                      "amount": "10000",
                      "maxTimeoutSeconds": 300,
                      "extra": {}
                    }
                  ]
                }
              }
            }
          },
          "501": {
            "description": "Wolfram|Alpha could not interpret the input or no sufficiently short result was available.",
            "content": {
              "text/plain": {
                "schema": {
