    "/v2/query": {
      "get": {
        "summary": "Get full structured Wolfram|Alpha results",
        "description": "Return the full Wolfram|Alpha result structure for a query. By default the upstream API returns XML, and `output=json` switches the response to JSON. This route also supports pod selection, pod states, location hints, timeout controls, and formula-oriented assumptions used by the Instant Calculators workflow.",
        "operationId": "getFullResults",
        "externalDocs": {
          "description": "Wolfram|Alpha Full Results API reference",
          "url": "https://products.wolframalpha.com/api/documentation"
        },
        "parameters": [
          {
            "$ref": "#/components/parameters/FullInput"
