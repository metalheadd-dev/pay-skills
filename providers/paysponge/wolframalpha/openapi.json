  "components": {
    "parameters": {
      "ShortInput": {
        "name": "i",
        "in": "query",
        "required": true,
        "description": "The natural-language Wolfram|Alpha query input. The short-answer and simple-image APIs document this parameter name as `i`.",
        "schema": {
          "type": "string",
          "minLength": 1
        },
        "example": "How far is Los Angeles from New York?"
      },
      "Units": {
        "name": "units",
        "in": "query",
        "required": false,
        "description": "Select the unit system for measurements and quantities.",
        "schema": {
          "type": "string",
          "enum": [
            "metric",
            "imperial"
          ]
        }
      },
      "Timeout": {
        "name": "timeout",
        "in": "query",
        "required": false,
        "description": "Maximum processing time in seconds. Wolfram documents a default of 5 seconds for the short-answer and simple-image APIs.",
        "schema": {
          "type": "number",
          "minimum": 0
        },
        "example": 5
      },
      "Layout": {
        "name": "layout",
        "in": "query",
        "required": false,
        "description": "Presentation style for simple-image output.",
        "schema": {
          "type": "string",
          "enum": [
            "divider",
            "labelbar"
          ]
        }
      },
      "Background": {
        "name": "background",
        "in": "query",
        "required": false,
        "description": "Background color for the rendered simple-image output. Wolfram documents HTML color names, hexadecimal RGB values, comma-separated RGB values, RGBA-like values with alpha, and `transparent` or `clear`.",
        "schema": {
          "type": "string"
        },
        "example": "F5F5F5"
      },
      "Foreground": {
        "name": "foreground",
        "in": "query",
        "required": false,
        "description": "Foreground text color for simple-image output.",
        "schema": {
          "type": "string",
          "enum": [
            "black",
            "white"
          ]
        }
      },
      "FontSize": {
        "name": "fontsize",
        "in": "query",
        "required": false,
        "description": "Display size of text elements in points. Wolfram documents a default of 14.",
        "schema": {
          "type": "integer",
          "minimum": 1
        },
        "example": 16
      },
      "Width": {
        "name": "width",
        "in": "query",
        "required": false,
        "description": "Desired width in pixels. Wolfram documents a default of 500 for the Simple API and uses width controls for image-oriented Full Results formats as well.",
        "schema": {
          "type": "integer",
          "minimum": 1
        },
        "example": 400
      },
      "FullInput": {
        "name": "input",
        "in": "query",
        "required": true,
        "description": "The natural-language Wolfram|Alpha query input for the Full Results API.",
        "schema": {
          "type": "string",
          "minLength": 1
        },
        "example": "population of france"
      },
      "Output": {
        "name": "output",
        "in": "query",
        "required": false,
        "description": "Switch the documented Full Results response from its default XML shape to JSON. Wolfram documents `output=json`; omitting the parameter returns XML.",
        "schema": {
          "type": "string"
        },
        "example": "json"
      },
      "Format": {
        "name": "format",
        "in": "query",
        "required": false,
        "description": "Comma-separated list of pod output formats to include. The Full Results docs explicitly describe `image`, `imagemap`, `plaintext`, `mathml`, `minput`, `moutput`, and `cell`.",
        "style": "form",
        "explode": false,
        "schema": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "image",
              "imagemap",
              "plaintext",
              "mathml",
              "minput",
              "moutput",
              "cell"
            ]
          }
        },
        "example": [
          "plaintext",
          "image"
        ]
      },
      "Assumption": {
        "name": "assumption",
        "in": "query",
        "required": false,
        "description": "One or more Wolfram assumption directives. This includes ordinary interpretation assumptions from Full Results and the formula-oriented assumption forms documented by the Instant Calculators API, such as `FSelect_**RAIDArray-`, `*FP.RAIDArray.RAIDLevel-_RAID6`, `*F.RAIDArray.disks-_4`, `*FS-_**RAIDArray.size--`, and `*FVarOpt-_**RAIDArray.spareDisks--`.",
        "style": "form",
        "explode": true,
        "schema": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "PodState": {
        "name": "podstate",
        "in": "query",
        "required": false,
        "description": "One or more pod-state changes from the `input` attribute of a `<state>` element, used for drilldown and alternate pod views. Wolfram also documents the multiplicity shortcut form such as `2@DecimalApproximation__More digits`.",
        "style": "form",
        "explode": true,
        "schema": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "example": [
          "DecimalApproximation__More digits"
        ]
      },
      "IncludePodId": {
        "name": "includepodid",
        "in": "query",
        "required": false,
        "description": "Pod IDs to include in the result. Use repeated parameters for multiple values.",
        "style": "form",
        "explode": true,
        "schema": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "ExcludePodId": {
        "name": "excludepodid",
        "in": "query",
        "required": false,
        "description": "Pod IDs to exclude from the result. Use repeated parameters for multiple values.",
        "style": "form",
        "explode": true,
        "schema": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "PodTitle": {
        "name": "podtitle",
        "in": "query",
        "required": false,
        "description": "Pod titles to include in the result. Wolfram documents `*` wildcard matching and repeated parameters for multiple values.",
        "style": "form",
        "explode": true,
        "schema": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "PodIndex": {
        "name": "podindex",
        "in": "query",
        "required": false,
        "description": "Comma-separated pod indices to return.",
        "style": "form",
        "explode": false,
        "schema": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "example": [
          1,
          2,
          4
        ]
      },
      "Scanner": {
        "name": "scanner",
        "in": "query",
        "required": false,
        "description": "One or more scanner names to include. Wolfram documents both comma-separated and repeated forms.",
        "style": "form",
        "explode": true,
        "schema": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "example": [
          "Numeric",
          "MathematicalFunctionData"
        ]
      },
      "Location": {
        "name": "location",
        "in": "query",
        "required": false,
        "description": "Location string used to guide geospatial interpretation and local defaults.",
        "schema": {
          "type": "string"
        },
        "example": "Champaign, Illinois"
      },
      "LatLong": {
        "name": "latlong",
        "in": "query",
        "required": false,
        "description": "Latitude and longitude hint used to determine a location.",
        "schema": {
          "type": "string"
        },
        "example": "40.1164,-88.2434"
      },
      "Ip": {
        "name": "ip",
        "in": "query",
        "required": false,
        "description": "Caller IP address to determine location. Wolfram documents this for forwarded end-user requests.",
        "schema": {
          "type": "string"
        },
        "example": "203.0.113.42"
      },
      "MaxWidth": {
        "name": "maxwidth",
        "in": "query",
        "required": false,
        "description": "Maximum width to use for returned pod images or cell renderings.",
        "schema": {
          "type": "integer",
          "minimum": 1
        }
      },
      "PlotWidth": {
        "name": "plotwidth",
        "in": "query",
        "required": false,
        "description": "Requested plot width for graphical results.",
        "schema": {
          "type": "integer",
          "minimum": 1
        }
      },
      "Magnification": {
        "name": "mag",
        "in": "query",
        "required": false,
        "description": "Image magnification factor for certain rendered outputs.",
        "schema": {
          "type": "number",
          "minimum": 0
        }
      },
      "ScanTimeout": {
        "name": "scantimeout",
        "in": "query",
        "required": false,
        "description": "Maximum time in seconds for the scan stage. Wolfram documents a default of 3 seconds.",
        "schema": {
          "type": "number",
          "minimum": 0
        },
        "example": 1
      },
      "PodTimeout": {
        "name": "podtimeout",
        "in": "query",
        "required": false,
        "description": "Maximum time in seconds for formatting any one pod before it is dropped from the output.",
        "schema": {
          "type": "number",
          "minimum": 0
        },
        "example": 0.3
      },
      "FormatTimeout": {
        "name": "formattimeout",
        "in": "query",
        "required": false,
        "description": "Maximum time in seconds for the entire format stage.",
        "schema": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "schemas": {
      "QueryResponse": {
        "type": "object",
        "properties": {
          "queryresult": {
            "$ref": "#/components/schemas/QueryResult"
          }
        },
